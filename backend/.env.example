# ── LLM (required) ──────────────────────────────────────────
# Free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=
LLM_PROVIDER=groq

# ── Auth ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# ── Razorpay Payments ────────────────────────────────────────
# Free account at: https://razorpay.com (use Test Mode keys)
# Test card: 4111 1111 1111 1111 | CVV: any 3 digits | Expiry: any future date
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ── Email (optional) ─────────────────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → create app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=MedCode AI <your_gmail@gmail.com>

# ── Server ──────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
